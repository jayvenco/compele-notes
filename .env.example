# ── Verplicht ─────────────────────────────────────────────
# Jouw GitHub gebruikersnaam (lowercase)
GITHUB_USER=jayvenco

# ── Optioneel ──────────────────────────────────────────────
# Poort waarop de app bereikbaar is (standaard 3737)
NOTES_PORT=3737

# Image tag — gebruik "latest" of een specifieke sha-xxxxx tag
# NOTES_TAG=latest

# Unraid: paden voor blijvende opslag (bij leeg = Docker named volumes)
# NOTES_DATA=/mnt/user/appdata/compele-notes/data
# NOTES_UPLOADS=/mnt/user/appdata/compele-notes/uploads
