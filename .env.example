# ── Verplicht ─────────────────────────────────────────────
# Jouw GitHub gebruikersnaam of organisatie (lowercase)
GITHUB_USER=jayvenco

# ── Optioneel ──────────────────────────────────────────────
# Poort waarop de app bereikbaar is (standaard 8080)
NOTES_PORT=8080

# Image tag — gebruik "latest" of een specifieke sha-xxxxx tag
# NOTES_TAG=latest

# Unraid: paden voor blijvende opslag (bij leeg = Docker named volumes)
# NOTES_DATA=/mnt/user/appdata/notes/data
# NOTES_UPLOADS=/mnt/user/appdata/notes/uploads
